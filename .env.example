# Supabase credentials for telemetry (play session analytics).
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real credentials.
#
# Client-side (inlined at build time by Vite's import.meta.env):
# Also set these in Vercel: Settings → Environment Variables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (migration script + future analytics API).
# Generate at: https://supabase.com/dashboard/account/tokens
# Set in Vercel + GitHub secrets. NEVER in client code.
SUPABASE_ACCESS_TOKEN=your-access-token-here
SUPABASE_PROJECT_REF=your-project-ref
