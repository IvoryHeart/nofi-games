{
  "name": "nofi-games",
  "version": "1.0.0",
  "description": "NoFi Games - Offline casual games collection. Play anywhere, anytime.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "db:migrate": "node scripts/migrate.mjs",
    "autoplay": "vitest run --config vitest.autoplay.ts",
    "analyze": "node scripts/analyze.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cap:sync": "npx cap sync",
    "build:android": "npm run build && npx cap sync android",
    "build:ios": "npm run build && npx cap sync ios",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "build:desktop": "npm run build && cd src-tauri && cargo build --release",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/sync-sandpack-bundler.js"
  },
  "keywords": [
    "games",
    "offline",
    "puzzle",
    "casual"
  ],
  "author": "IvoryHeart",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.7.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.2",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4.1.2",
    "workbox-precaching": "^7.3.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.12",
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/react": "^1.2.12",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@codesandbox/sandpack-react": "^2.20.0",
    "@octokit/auth-app": "^7.2.2",
    "@octokit/rest": "^21.1.1",
    "ai": "^4.3.19",
    "idb-keyval": "^6.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.25.76"
  }
}
